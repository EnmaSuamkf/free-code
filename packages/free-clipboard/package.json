{
	"name": "@free/clipboard",
	"version": "0.66.1",
	"private": true,
	"description": "Native clipboard bindings (vendored for free-code). Platform packages remain on npm under the upstream scope.",
	"main": "index.js",
	"types": "index.d.ts",
	"napi": {
		"name": "clipboard",
		"triples": {
			"additional": [
				"aarch64-apple-darwin",
				"aarch64-unknown-linux-gnu",
				"aarch64-unknown-linux-musl",
				"aarch64-pc-windows-msvc",
				"universal-apple-darwin",
				"riscv64gc-unknown-linux-gnu",
				"x86_64-unknown-linux-musl"
			]
		}
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/badlogic/clipboard.git"
	},
	"engines": {
		"node": ">= 10"
	},
	"optionalDependencies": {
		"@mariozechner/clipboard-win32-x64-msvc": "0.3.2",
		"@mariozechner/clipboard-darwin-x64": "0.3.2",
		"@mariozechner/clipboard-linux-x64-gnu": "0.3.2",
		"@mariozechner/clipboard-darwin-arm64": "0.3.2",
		"@mariozechner/clipboard-linux-arm64-gnu": "0.3.2",
		"@mariozechner/clipboard-linux-arm64-musl": "0.3.2",
		"@mariozechner/clipboard-win32-arm64-msvc": "0.3.2",
		"@mariozechner/clipboard-darwin-universal": "0.3.2",
		"@mariozechner/clipboard-linux-riscv64-gnu": "0.3.2",
		"@mariozechner/clipboard-linux-x64-musl": "0.3.2"
	}
}

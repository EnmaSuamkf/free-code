{
	"name": "@free/mini-lit",
	"version": "0.66.1",
	"private": true,
	"description": "Lightweight Lit components (vendored for free-code)",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": ["dist", "src/styles", "README.md", "llms.txt"],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./dist/*": "./dist/*",
		"./styles/*": "./src/styles/*"
	},
	"dependencies": {
		"@preact/signals-core": "^1.12.1",
		"class-variance-authority": "^0.7.1",
		"diff": "^8.0.2",
		"highlight.js": "^11.11.1",
		"html-parse-string": "^0.0.9",
		"katex": "^0.16.22",
		"lucide": "^0.544.0",
		"marked": "^16.3.0",
		"tailwind-merge": "^3.3.1",
		"tailwind-variants": "^3.1.1",
		"uhtml": "^5.0.9"
	},
	"peerDependencies": {
		"lit": "^3.3.1"
	}
}

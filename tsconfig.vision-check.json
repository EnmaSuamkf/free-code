{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"paths": {
			"@free/pi-coding-agent": ["./packages/coding-agent/src/index.ts"],
			"@free/pi-coding-agent/*": ["./packages/coding-agent/src/*"],
			"@free/pi-ai": ["./packages/ai/src/index.ts"],
			"@free/pi-ai/*": ["./packages/ai/src/*"],
			"@free/pi-tui": ["./packages/tui/src/index.ts"]
		},
		"rootDir": "."
	},
	"include": [
		"packages/coding-agent/default-extensions/vision.ts",
		"packages/coding-agent/default-extensions/lib/vision/config.ts",
		"packages/coding-agent/default-extensions/lib/vision/capture.ts",
		"packages/coding-agent/default-extensions/lib/vision/stt.ts",
		"packages/coding-agent/default-extensions/lib/vision/tts.ts"
	]
}

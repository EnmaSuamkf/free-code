{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@free/code-graph": ["./packages/code-graph/src/index.ts"],
			"@free/code-graph/*": ["./packages/code-graph/src/*"],
			"@free/jiti": ["./packages/free-jiti/lib/jiti.d.cts"],
			"@free/pi-ai": ["./packages/ai/src/index.ts"],
			"@free/pi-ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@free/pi-ai/*": ["./packages/ai/src/*.ts", "./packages/ai/src/providers/*.ts"],
			"@free/pi-ai/dist/*": ["./packages/ai/src/*"],
			"@free/pi-agent-core": ["./packages/agent/src/index.ts"],
			"@free/pi-agent-core/*": ["./packages/agent/src/*"],
			"@free/pi-coding-agent": ["./packages/coding-agent/src/index.ts"],
			"@free/pi-coding-agent/hooks": ["./packages/coding-agent/src/core/hooks/index.ts"],
			"@free/pi-coding-agent/*": ["./packages/coding-agent/src/*"],
			"@sinclair/typebox": ["./node_modules/@sinclair/typebox"],
			"@free/pi-mom": ["./packages/mom/src/index.ts"],
			"@free/pi-mom/*": ["./packages/mom/src/*"],
			"@free/pi": ["./packages/pods/src/index.ts"],
			"@free/pi/*": ["./packages/pods/src/*"],
			"@free/pi-tui": ["./packages/tui/src/index.ts"],
			"@free/pi-tui/*": ["./packages/tui/src/*"],
			"@free/pi-web-ui": ["./packages/web-ui/src/index.ts"],
			"@free/pi-web-ui/*": ["./packages/web-ui/src/*"],
			"@free/pi-agent-old": ["./packages/agent-old/src/index.ts"],
			"@free/pi-agent-old/*": ["./packages/agent-old/src/*"]
		}
	},
	"include": ["packages/*/src/**/*", "packages/*/test/**/*"],
	"exclude": ["packages/web-ui/**/*", "**/dist/**"]
}
